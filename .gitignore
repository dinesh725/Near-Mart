# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ── Environment files (NEVER commit secrets) ──────────────────────────────────
.env
.env.*
!.env.example

# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/
/.pnp
.pnp.js

# ── Build output ──────────────────────────────────────────────────────────────
/build
/dist
build.log

# ── Capacitor native platforms ────────────────────────────────────────────────
/android
/ios

# ── Firebase / Service Account keys ──────────────────────────────────────────
**/firebase-service-account.json
**/serviceAccountKey.json
**/firebase-adminsdk*.json

# ── Logs ──────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── OS files ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini

# ── IDE / Editor ──────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo

# ── Uploads & temp files ──────────────────────────────────────────────────────
uploads/
temp/
tmp/

# ── Testing ───────────────────────────────────────────────────────────────────
/coverage
