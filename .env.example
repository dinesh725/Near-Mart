# ═══════════════════════════════════════════════════════════════════════════════
# NearMart Environment Variables
# Copy this file to .env.local and fill in your values.
# Variables prefixed with REACT_APP_ are exposed to the browser at build time.
# ═══════════════════════════════════════════════════════════════════════════════

# ── API Configuration ────────────────────────────────────────────────────────
# Backend API base URL (must include /api prefix)
# Development:  http://localhost:5000/api
# Production:   https://api.nearmart.in/api
REACT_APP_API_URL=http://localhost:5000/api

# ── App Configuration ────────────────────────────────────────────────────────
# App version displayed in the mode-bar
REACT_APP_VERSION=0.1.0

# ── Feature Flags ────────────────────────────────────────────────────────────
# Enable push notification prompts (requires backend + VAPID keys)
REACT_APP_ENABLE_PUSH=false

# Enable Razorpay payment gateway
REACT_APP_ENABLE_PAYMENTS=true

# ── Razorpay ─────────────────────────────────────────────────────────────────
REACT_APP_RAZORPAY_KEY_ID=rzp_test_YOUR_KEY_HERE

# ── Mapbox ───────────────────────────────────────────────────────────────────
# Get your free token at https://account.mapbox.com/access-tokens/
REACT_APP_MAPBOX_TOKEN=YOUR_MAPBOX_TOKEN_HERE

# ── Notes ────────────────────────────────────────────────────────────────────
# • For Capacitor (Android/iOS) builds, set REACT_APP_API_URL to your
#   production HTTPS API endpoint before running `npm run build`.
# • Never commit .env.local — it is git-ignored by default.
# • CORS: Your backend must allow origins:
#     - http://localhost:3000    (dev)
#     - capacitor://localhost    (iOS Capacitor)
#     - http://localhost         (Android Capacitor)
#     - https://yourapp.com     (production web)

# ── Google OAuth ─────────────────────────────────────────────────────────────
REACT_APP_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
